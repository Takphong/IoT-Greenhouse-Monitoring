        "type": "function",
        "z": "9252db3cba6e71e5",
        "name": "function 3",
        "func": "msg.topic = \"INSERT INTO environment (temp, humidity, flame, pump) VALUES (?, ?, ?, ?)\";\n\nlet d = msg.payload.data || msg.payload;\n\nnode.warn(d); // must show\n\nmsg.payload = [\n    d.temp,\n    d.humidity,\n    d.flame ? 1 : 0,\n    d.pump ? 1 : 0\n];\n\nreturn msg;",
