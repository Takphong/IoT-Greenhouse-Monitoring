    {
        "id": "467e9ba16e99caea",
        "type": "function",
        "z": "9252db3cba6e71e5",
        "name": "function 7",
        "func": "// Extract parts\nlet receivedChecksum = msg.payload.checksum;\nlet dataObj = msg.payload.data;\n\n// Convert data back to string (same as ESP)\nlet dataStr = JSON.stringify(dataObj);\n\n// Generate checksum (same logic as ESP32)\nlet sum = 0;\nfor (let i = 0; i < dataStr.length; i++) {\n    sum += dataStr.charCodeAt(i);\n}\nsum = sum & 0xFFFF; // keep it 16-bit\n\n// Compare\nif (sum !== receivedChecksum) {\n    node.warn(\"❌ CHECKSUM FAILED\");\n    return null; // DROP message\n}\n\n// ✅ Passed\nnode.warn(\"✅ CHECKSUM OK\");\n\n// Replace payload with clean data\nmsg.payload = dataObj;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 460,
        "y": 160,
        "wires": [
            []
        ]
